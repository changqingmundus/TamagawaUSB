<UserControl x:Class="WPF.DialControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Width="300" Height="300">

    <Grid Background="Transparent">
        <Viewbox Stretch="Uniform">
            <Grid Width="300" Height="300">

                <Ellipse Stroke="#FFA5A5A5" StrokeThickness="4" Fill="#FFE8ECEF">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#44000000" Direction="270" ShadowDepth="2"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Margin="5" Stroke="#FFBBBBBB" StrokeThickness="1.5"/>
                <Ellipse Margin="10" Stroke="#FFD0D0D0" StrokeThickness="1"/>

                <Grid Width="300" Height="300">
                    <Grid.Resources>
                        <Grid x:Key="Sector30Deg" x:Shared="false" Width="300" Height="300">
                            <Line X1="150" Y1="12" X2="150" Y2="28" Stroke="#FF000000" StrokeThickness="1.5"/>

                            <Line X1="150" Y1="12" X2="150" Y2="18" Stroke="#FF555555" StrokeThickness="0.6">
                                <Line.RenderTransform>
                                    <RotateTransform CenterX="150" CenterY="150" Angle="5"/>
                                </Line.RenderTransform>
                            </Line>
                            <Line X1="150" Y1="12" X2="150" Y2="22" Stroke="#FF222222" StrokeThickness="1.0">
                                <Line.RenderTransform>
                                    <RotateTransform CenterX="150" CenterY="150" Angle="10"/>
                                </Line.RenderTransform>
                            </Line>
                            <Line X1="150" Y1="12" X2="150" Y2="18" Stroke="#FF555555" StrokeThickness="0.6">
                                <Line.RenderTransform>
                                    <RotateTransform CenterX="150" CenterY="150" Angle="15"/>
                                </Line.RenderTransform>
                            </Line>
                            <Line X1="150" Y1="12" X2="150" Y2="22" Stroke="#FF222222" StrokeThickness="1.0">
                                <Line.RenderTransform>
                                    <RotateTransform CenterX="150" CenterY="150" Angle="20"/>
                                </Line.RenderTransform>
                            </Line>
                            <Line X1="150" Y1="12" X2="150" Y2="18" Stroke="#FF555555" StrokeThickness="0.6">
                                <Line.RenderTransform>
                                    <RotateTransform CenterX="150" CenterY="150" Angle="25"/>
                                </Line.RenderTransform>
                            </Line>
                        </Grid>
                    </Grid.Resources>

                    <ContentControl Content="{StaticResource Sector30Deg}"/>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="30"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="60"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="90"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="120"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="150"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="180"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="210"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="240"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="270"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="300"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    <ContentControl Content="{StaticResource Sector30Deg}">
                        <ContentControl.RenderTransform>
                            <RotateTransform CenterX="150" CenterY="150" Angle="330"/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                </Grid>

                <Ellipse Margin="28" Stroke="#FFA0A0A0" StrokeThickness="1"/>

                <Canvas Width="300" Height="300">
                    <TextBlock Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#FF111111" Canvas.Left="143" Canvas.Top="27"/>
                    <TextBlock Text="30" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="193" Canvas.Top="42"/>
                    <TextBlock Text="60" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="229" Canvas.Top="82" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.135,1.167"/>
                    <TextBlock Text="90" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="243" Canvas.Top="139" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="120" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="218" Canvas.Top="193" RenderTransformOrigin="0.31,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="150" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="182" Canvas.Top="233" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="180" FontSize="22" FontWeight="SemiBold" Foreground="#FF111111" Canvas.Left="129" Canvas.Top="244" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <TextBlock Text="210" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="87" Canvas.Top="233" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="240" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="49" Canvas.Top="193"/>
                    <TextBlock Text="270" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="32" Canvas.Top="139" RenderTransformOrigin="0.861,0.044" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="300" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="49" Canvas.Top="82" RenderTransformOrigin="0.961,0.131" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <TextBlock Text="330" FontSize="18" FontWeight="SemiBold" Foreground="#FF222222" Canvas.Left="87" Canvas.Top="42"/>
                </Canvas>

                <Ellipse Width="64" Height="64" Stroke="#FF666666" StrokeThickness="1.2" Fill="#FFE8ECEF"/>

                <Path Data="M 148.5,118 L 149.3,38 L 150,23 L 150.7,38 L 151.5,118 Z" Fill="#FFED1C24" Stroke="#FFC4131A" StrokeThickness="0.5">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="PointerTransform" Angle="0" CenterX="150" CenterY="150"/>
                    </Path.RenderTransform>
                </Path>

                <Ellipse Width="2" Height="2" Fill="#FF444444"/>

            </Grid>
        </Viewbox>
    </Grid>
</UserControl>